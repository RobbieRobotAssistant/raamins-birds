# Web frontend configuration. Copy to .env.local for local dev; set the same
# vars in the Vercel project for production (see DEPLOY.md).

# Base URL of the Pi API via the Cloudflare Tunnel. NO trailing slash.
# Leave EMPTY to run the frontend entirely on built-in mock data.
# Example: https://api.birds.example.com
BIRD_API_URL=

# Public URL of species.json produced by the image-gen script (Vercel Blob).
# Leave EMPTY to use computed fallbacks (text placeholders + derived links).
# Example: https://<store>.public.blob.vercel-storage.com/species.json
SPECIES_DATA_URL=

# Force mock mode even when BIRD_API_URL is set (handy for previews). "1" = on.
USE_MOCKS=

# Cosmetic: shown in the header.
NEXT_PUBLIC_SITE_NAME=Garden Birds
NEXT_PUBLIC_SITE_LOCATION=Utrecht, NL
