# Pi API configuration. Copy to .env on the Pi (the systemd unit reads it).

# Absolute path to the read-only BirdNET-Pi SQLite database.
BIRDS_DB_PATH=/home/rmostag1/BirdNET-Pi/scripts/birds.db

# Absolute path to the extracted audio clips, organized By_Date.
BIRDSONGS_DIR=/home/rmostag1/BirdNET-Pi/BirdSongs/Extracted/By_Date

# Comma-separated list of allowed CORS origins. ONLY your Vercel domain(s).
# No trailing slash. Example: https://birds.example.com,https://www.birds.example.com
ALLOWED_ORIGINS=https://CHANGE-ME.vercel.app

# Host/port uvicorn binds to. cloudflared connects to this locally.
API_HOST=127.0.0.1
API_PORT=8000

# --- Moderation (delete misidentified detections via BirdNET-Pi) ---
# Shared secret required to call POST /api/moderate/delete/{rowid}. Must match
# the MODERATION_TOKEN set in Vercel. Empty = moderation disabled.
MODERATION_TOKEN=
# BirdNET-Pi's own web UI on the Pi; its play.php does the actual deletion.
BIRDNETPI_URL=http://localhost
BIRDNETPI_USER=birdnet
BIRDNETPI_PASSWORD=
