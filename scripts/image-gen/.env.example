# image-gen configuration. Run: npm run generate  (add --dry-run to test).

# Pi API base (Cloudflare Tunnel URL), used to list detected species.
BIRD_API_URL=https://api.birds.example.com

# Public URL of the existing species.json (so runs are idempotent). Same value
# as the frontend's SPECIES_DATA_URL. Leave empty on the very first run.
SPECIES_DATA_URL=

# Vercel Blob write token. Required for real uploads (not needed for --dry-run).
BLOB_READ_WRITE_TOKEN=

# Image provider: "none" (default) uploads no images — the frontend shows a
# common-name text placeholder, your signal to drop a real image into
# ./provided-images. "openai" is stubbed (see src/providers.ts TODO).
IMAGE_PROVIDER=none

# Only used when IMAGE_PROVIDER=openai (currently a stub).
OPENAI_API_KEY=
OPENAI_IMAGE_MODEL=gpt-image-1

# Hard cap on AI generations per run, to bound cost.
MAX_GENERATIONS=10
