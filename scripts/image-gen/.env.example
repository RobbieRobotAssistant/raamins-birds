# Species text-enrichment configuration. Run: npm run generate (add --dry-run).

# Pi API base (Cloudflare Tunnel URL), used to list detected species.
BIRD_API_URL=https://api.birds.raaminmostaghimi.com

# Public URL of the existing species.json (so runs are idempotent). Same value
# as the frontend's SPECIES_DATA_URL. Leave empty on the very first run.
SPECIES_DATA_URL=

# Vercel Blob write token. Required for real uploads (not needed for --dry-run).
BLOB_READ_WRITE_TOKEN=
